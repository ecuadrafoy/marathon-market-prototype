<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="EncounterBalanced">
    <Selector name="BalancedEngageDecision">
      <Condition ID="OpponentHelpless"/>
      <Sequence name="HighValueGuarded">
        <Condition ID="CarryingHighValue"/>
        <Condition ID="CombatRatioAbove" threshold="1.2"/>
      </Sequence>
      <Sequence name="StandardEvenOdds">
        <Inverter>
          <Condition ID="CarryingHighValue"/>
        </Inverter>
        <Condition ID="CombatRatioAbove" threshold="0.9"/>
      </Sequence>
    </Selector>
  </BehaviorTree>
</root>
