<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="EncounterSupport">
    <Selector name="SupportEngageDecision">
      <Condition ID="OpponentHelpless"/>
      <Sequence name="CarryingAnything">
        <Condition ID="CarryingAnything"/>
        <Condition ID="CombatRatioAbove" threshold="1.8"/>
      </Sequence>
      <Sequence name="EmptyHands">
        <Condition ID="CarryingNothing"/>
        <Condition ID="CombatRatioAbove" threshold="1.5"/>
      </Sequence>
    </Selector>
  </BehaviorTree>
</root>
