<root BTCPP_format="4">
  <BehaviorTree ID="EncounterCautious">
    <Selector name="CautiousEngageDecision">
      <Condition ID="OpponentHelpless"/>
      <Sequence name="HighValueGuarded">
        <Condition ID="CarryingHighValue"/>
        <Condition ID="CombatRatioAbove" threshold="1.5"/>
      </Sequence>
      <Sequence name="StandardCaution">
